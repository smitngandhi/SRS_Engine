# ══════════════════════════════════════════════════════════════════════════════
# SPECFORGE AI — ENVIRONMENT CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════

# ── API & CORE ───────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false
SECRET_KEY=generate_a_long_random_string_here

# ── DATABASE (MongoDB Atlas Free Tier) ────────────────────────────────────────
# Example: mongodb+srv://<user>:<password>@cluster.mongodb.net/specforgeai
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=specforgeai

# ── CACHE & QUEUE (Render/Upstash Free Redis) ─────────────────────────────────
# Use 'redis://localhost:6379' for local dev
REDIS_URL=redis://localhost:6379

# ── AI ENGINE (Groq Free Tier) ───────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=groq/meta-llama/llama-4-scout-17b-16e-instruct

# ── AUTH (Google OAuth 2.0) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── ADMINISTRATIVE ────────────────────────────────────────────────────────────
# The primary account that bypasses all quotas and has system access
ADMIN_EMAIL=hello.specforge@gmail.com

# ── EMAIL (SMTP/SendGrid/Resend) ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hello.specforge@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAILS_FROM_NAME=SpecForge AI
EMAILS_FROM_EMAIL=hello.specforge@gmail.com