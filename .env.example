GROQ_API_KEY = <YOUR_API_KEY_HERE>
GROQ_MODEL = groq/meta-llama/llama-4-scout-17b-16e-instruct

# ------------------------------
# Authentication / Sessions
# ------------------------------
# Used by Starlette SessionMiddleware to sign cookies
SESSION_SECRET_KEY = <SET_A_LONG_RANDOM_SECRET>

# ------------------------------
# MongoDB (Users)
# ------------------------------
MONGODB_URI = mongodb://localhost:27017
MONGODB_DB = srs_engine

# ------------------------------
# Google OAuth (Login)
# ------------------------------
GOOGLE_OAUTH_CLIENT_ID = <YOUR_GOOGLE_CLIENT_ID>
GOOGLE_OAUTH_CLIENT_SECRET = <YOUR_GOOGLE_CLIENT_SECRET>
GOOGLE_OAUTH_REDIRECT_URI = http://127.0.0.1:8000/auth/google/callback

# ------------------------------
# Contact form email (SMTP)
# ------------------------------
SMTP_HOST = <SMTP_HOST>
SMTP_PORT = 587
SMTP_USERNAME = <SMTP_USERNAME>
SMTP_PASSWORD = <SMTP_PASSWORD>
SMTP_FROM_EMAIL = <FROM_EMAIL_ADDRESS>
SMTP_TO_EMAIL = smitgandhi585@gmail.com

# ------------------------------
# Logging
# ------------------------------
LOG_LEVEL = INFO
LOG_DIR = ./logs